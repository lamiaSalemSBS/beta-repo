<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_order_form_inherit_beta_enquiry_ref" model="ir.ui.view">
    <field name="name">sale.order.form.beta.enquiry.ref</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">
      <!-- Insert right after Payment Terms field -->
      <xpath expr="//field[@name='payment_term_id']" position="after">
        <field name="buyer_order_no"/>
        <field name="buyer_order_date"/>
        <field name="proforma_invoice_date"/>
        <field name="vessel_name"/>
        <field name="mode_of_transport"/>
      </xpath>
    </field>
  </record>
</odoo>
