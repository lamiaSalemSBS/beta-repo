<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for CRM Enquiry -->
        <record id="seq_crm_enquiry_custom" model="ir.sequence">
            <field name="name">CRM Enquiry Custom</field>
            <field name="code">crm.enquiry.custom</field>
            <field name="prefix">BETA-ENQ</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>

        <!-- Sequence for Beta Offer (Sale Order Draft/Sent) -->
        <record id="seq_beta_offer" model="ir.sequence">
            <field name="name">Beta Offer</field>
            <field name="code">sale.order.beta.offer</field>
            <field name="prefix">Beta-Offer</field>
            <field name="padding">6</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>
    </data>
</odoo>
