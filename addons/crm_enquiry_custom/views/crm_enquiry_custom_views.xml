<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_crm_enquiry_custom_form" model="ir.ui.view">
        <field name="name">crm.enquiry.custom.form</field>
        <field name="model">crm.enquiry.custom</field>
        <field name="arch" type="xml">
            <form string="Enquiry">
                <header>

                    <button name="action_confirm" string="Confirm" type="object"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_done" string="Done" type="object"
                            class="oe_highlight" invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state not in ['draft', 'confirmed']"/>
                    <button name="action_draft" string="Set to Draft" type="object"
                            invisible="state != 'cancel'"/>
                    <button name="action_create_revision" string="Revision" type="object"
                            class="btn-secondary"/>
                    <button name="action_create_quotation_enquiry" string="Create Quotation" type="object"
                            class="oe_highlight"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sale_orders" type="object"
                                class="oe_stat_button" icon="fa-usd">
                            <field name="sale_order_count" widget="statinfo" string="Quotations"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="lead_id" options="{'no_create': True}"/>
                            <field name="project_type_id" options="{'no_create': True}"/>
                            <field name="partner_id" options="{'no_create': True}"/>
                            <field name="customer_reference"/>
                            <field name="consignee"/>
                            <field name="notify"/>
                            <field name="company_id" invisible="True"/>
                            <field name="currency_id" invisible="True"/>
                        </group>
                        <group>
                            <field name="revision"/>
                            <field name="date"/>
                            <field name="project_reference_id" options="{'no_create': True}"/>
                            <field name="detail_template_id" options="{'no_create': True}" readonly="state in ['done', 'confirmed']"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Enquiry Lines" name="lines">
                            <field name="line_ids">
                                <list string="Lines" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="qty"/>
                                    <field name="note"/>
                                    <button name="action_show_details" type="object"
                                            string="Details" icon="fa-list"
                                            class="btn-primary"/>
                                </list>
                            </field>
                            <group name="note_group" col="6" class="mt-2 mt-md-0">
                                <group colspan="4" class="order-1 order-lg-0">
                                    <field colspan="2" name="notes" nolabel="1" placeholder="Terms and conditions..."/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Popup form view for enquiry line with details -->
    <record id="view_crm_enquiry_line_form" model="ir.ui.view">
        <field name="name">crm.enquiry.line.form</field>
        <field name="model">crm.enquiry.line</field>
        <field name="arch" type="xml">
            <form string="Enquiry Line Details">
                <sheet>
                    <group>
                        <group>
                            <field name="product_id" readonly="1"/>
                            <field name="name" readonly="1"/>
                        </group>
                        <group>
                            <field name="qty" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Details">
                            <field name="detail_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="parameter_id"
                                           options="{'no_quick_create': True,'no_create': False}"/>
                                    <field name="unit" optional="show"/>
                                    <field name="item_id"
                                           context="{'default_parameter_id': parameter_id}"
                                           options="{'no_open': True, 'no_create_edit': True}"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button string="Save" type="object" class="btn-primary" special="save"/>
                    <button string="Discard" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- CRM Enquiry Detail Form View (standalone) -->
    <record id="view_crm_enquiry_detail_form" model="ir.ui.view">
        <field name="name">crm.enquiry.detail.form</field>
        <field name="model">crm.enquiry.detail</field>
        <field name="arch" type="xml">
            <form string="Detail">
                <sheet>
                    <group>
                        <group>
                            <field name="parameter_id" options="{'no_create': True}"/>
                            <field name="unit" readonly="1"/>
                        </group>
                        <group>
                            <field name="item_id"
                                   context="{'default_parameter_id': parameter_id}"
                                   options="{'no_open': True, 'no_create_edit': True}"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- CRM Enquiry Detail List View -->
    <record id="view_crm_enquiry_detail_list" model="ir.ui.view">
        <field name="name">crm.enquiry.detail.list</field>
        <field name="model">crm.enquiry.detail</field>
        <field name="arch" type="xml">
            <list string="Details" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="description"/>
                <field name="unit"/>
            </list>
        </field>
    </record>

    <!-- List View -->
    <record id="view_crm_enquiry_custom_tree" model="ir.ui.view">
        <field name="name">crm.enquiry.custom.list</field>
        <field name="model">crm.enquiry.custom</field>
        <field name="arch" type="xml">
            <list string="Enquiries">
                <field name="name"/>
                <field name="lead_id"/>
                <field name="partner_id"/>
                <field name="project_reference"/>
                <field name="date"/>
                <field name="revision"/>
                <field name="customer_reference"/>
                <field name="state" decoration-success="state == 'done'"
                       decoration-info="state == 'confirmed'"
                       decoration-muted="state == 'cancel'"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_crm_enquiry_custom_search" model="ir.ui.view">
        <field name="name">crm.enquiry.custom.search</field>
        <field name="model">crm.enquiry.custom</field>
        <field name="arch" type="xml">
            <search string="Search Enquiries">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="lead_id"/>
                <field name="project_reference"/>
                <field name="customer_reference"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <group expand="0" string="Group By">
                    <filter string="Customer" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Lead" name="group_lead" context="{'group_by': 'lead_id'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_crm_enquiry_custom" model="ir.actions.act_window">
        <field name="name">Enquiries</field>
        <field name="res_model">crm.enquiry.custom</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Enquiry
            </p>
            <p>
                Create enquiries from CRM leads to track customer requests.
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_crm_enquiry_custom"
              name="Enquiries Item"
              parent="crm.crm_menu_sales"
              action="action_crm_enquiry_custom"
              sequence="10"/>
</odoo>
