<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Partner Bank Form View -->
    <record id="view_partner_bank_form_inherit" model="ir.ui.view">
        <field name="name">res.partner.bank.form.inherit</field>
        <field name="model">res.partner.bank</field>
        <field name="inherit_id" ref="base.view_partner_bank_form"/>
        <field name="arch" type="xml">
            <!-- Add custom fields after acc_number -->
            <xpath expr="//field[@name='acc_number']" position="after">
                <field name="iban"/>
                <field name="cx_code"/>
                <field name="bank_address"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit Partner Bank Tree View -->
    <record id="view_partner_bank_tree_inherit" model="ir.ui.view">
        <field name="name">res.partner.bank.tree.inherit</field>
        <field name="model">res.partner.bank</field>
        <field name="inherit_id" ref="base.view_partner_bank_tree"/>
        <field name="arch" type="xml">
            <!-- Add custom fields in tree view -->
            <xpath expr="//field[@name='acc_number']" position="after">
                <field name="iban" optional="show"/>
                <field name="cx_code" optional="hide"/>
                <field name="bank_address" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="view_product_template_hs_codes" model="ir.ui.view">
        <field name="name">view.product.template.hs.codes</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="before">
                <field name="hs_code"/>z
            </xpath>
        </field>
    </record>
</odoo>
