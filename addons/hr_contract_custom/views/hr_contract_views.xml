<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_contract_view_form_inherit" model="ir.ui.view">
        <field name="name">hr.contract.form.inherit</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <!-- Add fields after wage field -->
            <xpath expr="//div[@name='wage']" position="after">
                <!-- Total Salary Field (computed) -->
                <label for="salary"/>
                <div class="o_row mw-50" name="salary">
                    <field name="salary" class="oe_inline o_hr_narrow_field" nolabel="1" readonly="1"/>
                    <div class="mb-3" name="salary_period_label">/ month</div>
                </div>
                <!-- Food Allowance Field -->
                <label for="food"/>
                <div class="o_row mw-50" name="food">
                    <field name="food" class="oe_inline o_hr_narrow_field" nolabel="1"/>
                    <div class="mb-3" name="food_period_label">/ month</div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
