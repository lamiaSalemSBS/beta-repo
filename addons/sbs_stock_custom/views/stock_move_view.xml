<odoo>
    <record id="stock_picking_custom_flow" model="ir.ui.view">
        <field name="name">stock.picking.custom.flow</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <field name="show_validate" invisible="1"/>
            </xpath>
            <xpath expr="//button[@name='button_validate'][hasclass('o_btn_validate')]" position="attributes">
                <attribute name="invisible">not show_validate or state in ('waiting', 'assigned', 'done', 'cancel')</attribute>
            </xpath>
            <xpath expr="//button[@name='button_validate'][hasclass('oe_highlight')]" position="attributes">
                <attribute name="invisible">not show_validate or state in ('draft', 'confirmed', 'done', 'cancel')</attribute>
            </xpath>
        </field>
    </record>
</odoo>