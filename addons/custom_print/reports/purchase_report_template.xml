<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Main Purchase Order Report Template -->
    <template id="report_purchase_order_document_custom">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <t t-foreach="docs" t-as="doc">
                    <div class="header">
                        <!-- Header with Logo and Company Info -->
                        <div class="row">
                            <div class="col-6">
                                <!-- Company Logo -->
                                <img t-if="doc.company_id.logo" t-att-src="image_data_uri(doc.company_id.logo)"
                                     style="max-height: 80px; max-width: 200px;" alt="Company Logo"/>
                            </div>

                            <div class="col-6 text-start" style="margin-left:210px;">
                                <!-- Company Information -->
                                <strong>
                                    <span t-field="doc.company_id.name"/>
                                </strong>
                                <br/>
                                <span t-field="doc.company_id.street"/>
                                /
                                <span t-field="doc.company_id.street2"/>
                                <br/>
                                <span t-field="doc.company_id.city"/>,
                                <span t-field="doc.company_id.state_id"/>
                                <br/>
                                <t t-if="doc.company_id.phone">Tel:
                                    <span t-field="doc.company_id.phone"/>
                                    <br/>
                                </t>
                                <t t-if="doc.company_id.website">Website:
                                    <span t-field="doc.company_id.website"/>
                                    <br/>
                                </t>
                                <t t-if="doc.company_id.email">Email:
                                    <span t-field="doc.company_id.email"/>
                                    <br/>
                                </t>
                                <t t-if="doc.company_id.email">TRN NO. :
                                    <span t-field="doc.company_id.vat"/>
                                </t>
                            </div>
                        </div>
                    </div>

                    <div class="page">
                        <!-- Title Section -->
                        <div class="row">
                            <div class="col-6">
                                <h4 style="margin: 0;">

                                    <t t-if="doc.state in ['draft', 'sent', 'to approve']">Request for Quotation #
                                        <span t-field="doc.name"/>
                                    </t>
                                    <t t-if="doc.state in ['purchase', 'done']">Purchase Order #
                                        <span t-field="doc.name"/>
                                    </t>
                                    <t t-if="doc.state == 'cancel'">Cancelled Purchase Order #
                                        <span t-field="doc.name"/>
                                    </t>

                                </h4>
                            </div>
                            <div class="col-6">
                                <div class="text-end" name="right_box">
                                    <img t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', doc.name, 600, 100)"
                                         style="width:300px;height:50px;" alt="Barcode"/>
                                </div>
                            </div>
                        </div>
                        <!-- Supplier and PO Information Tables -->
                        <div class="row" style="margin-top: 15px;">
                            <!-- Supplier Information Table -->

                            <table class="table table-bordered">
                                <thead style="background-color: #f0f0f0;">
                                    <tr>
                                        <th></th>
                                        <th class="text-start">SUPPLIER INFORMATION</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td style="width: 20%;">
                                            <strong>Name:</strong>
                                        </td>
                                        <td style="width: 80%;">
                                            <span t-field="doc.partner_id.name"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Address:</strong>
                                        </td>
                                        <td>
                                            <span t-field="doc.partner_id.street"/>
                                            <t t-if="doc.partner_id.street2">
                                                /
                                                <span t-field="doc.partner_id.street2"/>
                                            </t>
                                            /
                                            <span t-field="doc.partner_id.city"/>
                                            /
                                            <span t-field="doc.partner_id.state_id"/>
                                            /
                                            <span t-field="doc.partner_id.country_id"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>TAX ID:</strong>
                                        </td>
                                        <td>
                                            <span t-field="doc.partner_id.vat"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Mobile:</strong>
                                        </td>
                                        <td>
                                            <span t-field="doc.partner_id.phone"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Email:</strong>
                                        </td>
                                        <td>
                                            <span t-field="doc.partner_id.email"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>

                        </div>
                        <div style="background-color: #f0f0f0; padding: 5px;">
                            <strong>PO INFORMATION</strong>
                        </div>
                        <div class="d-flex justify-content-between" style="margin-top: 5px;">
                            <div name="date">
                                <strong>Date</strong>
                                <div t-field="doc.date_order" class="m-0" t-options='{"widget": "date"}'/>
                            </div>
                            <div name="order_by">
                                <strong>Ordered by</strong>
                                <div t-field="doc.user_id.name" class="m-0"/>
                            </div>
                            <div name="payment">
                                <strong>Payment Terms</strong>
                                <div t-field="doc.payment_term_id" class="m-0"/>
                            </div>
                            <div name="delivery">
                                <strong>Delivery Terms</strong>
                                <div t-field="doc.picking_type_id" class="m-0"/>
                            </div>
                            <div name="currency">
                                <strong>Currency</strong>
                                <div t-field="doc.currency_id" class="m-0"/>
                            </div>
                        </div>

                        <!-- Currency and PO Number -->

                        <div class="mt-4">

                            <t t-if="doc.state in ['draft', 'sent', 'to approve']">Request for Quotation #
                                <span t-field="doc.name"/>
                            </t>
                            <t t-if="doc.state in ['purchase', 'done']">Purchase Order #
                                <span t-field="doc.name"/>
                            </t>
                            <t t-if="doc.state == 'cancel'">Cancelled Purchase Order #
                                <span t-field="doc.name"/>

                            </t>
                        </div>

                        <!-- Order Lines Table -->
                        <table class="table table-bordered" style="margin-top: 15px;">
                            <thead style="background-color: #f0f0f0;">
                                <tr>
                                    <th style="width: 4%;">Sl.No</th>
                                    <th style="width: 10%;">Item No.</th>
                                    <th style="width: 18%;">Description</th>
                                    <th style="width: 8%;" class="text-center">
                                        <t t-if="doc.print_layout == 'contract_agreement'">Quantity /Monthly (Nos)</t>
                                        <t t-else="">Quantity (Nos)</t>
                                    </th>
                                    <t t-if="doc.print_layout != 'normal_po'">
                                        <th style="width: 8%;" class="text-center">Weight (kg/Unit)</th>
                                        <th style="width: 9%;" class="text-center">
                                            <t t-if="doc.print_layout == 'contract_agreement'">Total Weight (kg) /Monthly
                                            </t>
                                            <t t-else="">Total Weight (kg)</t>
                                        </th>
                                    </t>
                                    <t t-if="doc.print_layout == 'contract_agreement'">
                                        <th style="width: 8%;" class="text-end">Price /Unit (USD)</th>
                                        <th style="width: 9%;" class="text-end">Monthly total Amount (USD)</th>
                                        <th style="width: 8%;" class="text-center">Months contract Qty (Nos)</th>
                                        <th style="width: 9%;" class="text-center">Months contract Total Weight (kg)
                                        </th>
                                        <th style="width: 9%;" class="text-end">Months contract amount (USD)</th>
                                        <th style="width: 8%;" class="text-center">Delivery Terms</th>
                                    </t>
                                    <t t-else="">
                                        <th style="width: 10%;" class="text-center">Delivery Date</th>
                                        <th style="width: 8%;" class="text-end">Unit Price (USD)</th>
                                        <th style="width: 8%;" class="text-end">Amount (USD)</th>
                                    </t>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="line_index" t-value="0"/>
                                <t t-foreach="doc.order_line" t-as="line">
                                    <t t-set="line_index" t-value="line_index + 1"/>
                                    <tr>
                                        <td class="text-center">
                                            <span t-esc="line_index"/>
                                        </td>
                                        <td>
                                            <span t-field="line.product_id.default_code"/>
                                        </td>
                                        <td>
                                            <span t-field="line.product_id.name"/>
                                            <t t-if="line.custom_description">
                                                <br/>
                                                <span t-field="line.custom_description"/>
                                            </t>
                                        </td>
                                        <td class="text-center">
                                            <t t-if="doc.print_layout == 'contract_agreement'">
                                                <span t-field="line.qty_monthly_nos"/>
                                            </t>
                                            <t t-else="">
                                                <span t-field="line.product_qty"/>
                                            </t>
                                        </td>
                                        <t t-if="doc.print_layout != 'normal_po'">
                                            <td class="text-center">
                                                <span t-field="line.weight_unit_kg"/>
                                            </td>
                                            <td class="text-center">
                                                <t t-if="doc.print_layout == 'contract_agreement'">
                                                    <span t-field="line.monthly_total_weight_kg"/>
                                                </t>
                                                <t t-else="">
                                                    <span t-field="line.total_weight_kg"/>
                                                </t>
                                            </td>
                                        </t>

                                        <t t-if="doc.print_layout == 'contract_agreement'">
                                            <td class="text-end">
                                                <span t-field="line.price_unit"/>
                                            </td>
                                            <td class="text-end">
                                                <span t-field="line.monthly_amount"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="line.product_qty"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="line.total_weight_kg"/>
                                            </td>
                                            <td class="text-end">
                                                <span t-field="line.price_subtotal"/>
                                            </td>
                                            <td class="text-center">
                                                <t t-if="line.delivery_date_text">
                                                    <span t-field="line.delivery_date_text"/>
                                                </t>
                                                <t t-else="">
                                                    <span t-field="line.date_planned" t-options='{"widget": "date"}'/>
                                                </t>
                                            </td>
                                        </t>
                                        <t t-else="">
                                            <td class="text-center">
                                                <t t-if="line.delivery_date_text">
                                                    <span t-field="line.delivery_date_text"/>
                                                </t>
                                                <t t-else="">
                                                    <span t-field="line.date_planned" t-options='{"widget": "date"}'/>
                                                </t>
                                            </td>
                                            <td class="text-end">
                                                <span t-field="line.price_unit"/>
                                            </td>
                                            <td class="text-end">
                                                <span t-field="line.price_subtotal"/>
                                            </td>
                                        </t>
                                    </tr>
                                </t>

                            </tbody>
                        </table>

                        <table class="table table-bordered" style="margin-top: 0; width: 100%;">
                            <tr style="background-color: #f0f0f0;">
                                <td style="width: 75%;" class="text-center">
                                    <strong>Sub Total</strong>
                                </td>
                                <td style="width: 25%;" class="text-end">
                                    <strong>
                                        <span t-field="doc.amount_untaxed"/>
                                    </strong>
                                </td>
                            </tr>
                            <tr style="background-color: #f0f0f0;">
                                <td class="text-center">
                                    <strong>VAT</strong>
                                </td>
                                <td class="text-end">
                                    <strong>
                                        <t t-if="doc.amount_untaxed > 0">
                                            <t t-set="vat_percent"
                                               t-value="(doc.amount_tax / doc.amount_untaxed) * 100"/>
                                            <span t-esc="'{:.2f}%'.format(vat_percent)"/>
                                        </t>
                                        <t t-if="doc.amount_untaxed == 0">0.00%</t>
                                    </strong>
                                </td>
                            </tr>
                            <tr style="background-color: #f0f0f0;">
                                <td class="text-center">
                                    <strong>Vat Amount</strong>
                                </td>
                                <td class="text-end">
                                    <strong>
                                        <span t-field="doc.amount_tax"/>
                                    </strong>
                                </td>
                            </tr>
                            <tr style="background-color: #f0f0f0;">
                                <td class="text-center">
                                    <strong>Total Amount</strong>
                                </td>
                                <td class="text-end">
                                    <strong>
                                        <span t-field="doc.amount_total"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </strong>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <strong>Amount in Words</strong>
                                </td>
                                <td>
                                    <span t-out="doc.currency_id.amount_to_text(doc.amount_total)"/>
                                </td>
                            </tr>
                        </table>
                        <br/>
                        <br/>
                        <br/>

                        <br/>
                        <br/>


                        <!-- Order Confirmation Section -->
                        <div style="margin-top: 40px; page-break-before: avoid;">
                            <!--                            <div class="text-center">-->
                            <!--                                <h4>PURCHASE ORDER</h4>-->
                            <!--                            </div>-->

                            <!--                            <div style="margin-top: 20px;">-->
