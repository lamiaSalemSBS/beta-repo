                        </div>

                    </div>

                    <div class="footer" style="font-size:14px; width:100%; padding-top:10px;">
                        <div class="row" style="margin:0; align-items:flex-end;">

                            <!-- Responsible DR -->
                            <div class="col-4 text-center">
                                <t t-if="doc.responsible_dr_id">
                                    <strong style="font-size:18px;">
                                        <span t-field="doc.responsible_dr_id.name"/>
                                    </strong>
                                    <br/>
                                    <span style="display:inline-block; width:220px; border-top:1px solid #000; margin-top:8px;"></span>
                                </t>
                            </div>

                            <!-- Page Number (CENTER) -->
                            <div class="col-4 text-center">
                                <strong style="font-size:15px;">
                                    Page <span class="page"/> / <span class="topage"/>
                                </strong>
                            </div>

                            <!-- Responsible ECO -->
                            <div class="col-4 text-center">
                                <t t-if="doc.responsible_eco_id">
