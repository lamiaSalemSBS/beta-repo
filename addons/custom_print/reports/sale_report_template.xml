<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Main Sale Order Report Template -->
    <template id="report_sale_order_document_custom">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <t t-foreach="docs" t-as="doc">
                    <div class="header">
                        <!-- Header with Logo and Company Info -->
                        <div class="row">
                            <div class="col-6">
                                <!-- Company Logo -->
                                <img t-if="doc.company_id.logo" t-att-src="image_data_uri(doc.company_id.logo)"
                                     style="max-height: 80px; max-width: 200px;" alt="Company Logo"/>
                            </div>
                              <div class="col-6 text-start" style="margin-left:210px;">
                                <!-- Company Information -->
                                <strong>
                                    <span t-field="doc.company_id.name"/>
                                </strong>
                                <br/>
                                <span t-field="doc.company_id.street"/>
                                /
                                <span t-field="doc.company_id.street2"/>
                                <br/>
                                <span t-field="doc.company_id.city"/>,
                                <span t-field="doc.company_id.state_id"/>
                                <br/>
                                <t t-if="doc.company_id.phone">Tel:
                                    <span t-field="doc.company_id.phone"/>
                                    <br/>
                                </t>
                                <t t-if="doc.company_id.website">Website:
                                    <span t-field="doc.company_id.website"/>
                                    <br/>
                                </t>
                                <t t-if="doc.company_id.email">Email:
                                    <span t-field="doc.company_id.email"/>
                                    <br/>
                                </t>
                                <t t-if="doc.company_id.vat">Vat Registration No.:
                                    <span t-field="doc.company_id.vat"/>
                                </t>
                            </div>
                        </div>
                    </div>

                    <div class="page">


                        <!-- Title Section -->
                        <div class="text-center"
                             style="background-color: #17a2b8; color: white; padding: 8px; margin-top: 10px;">
                            <h3 style="margin: 0;">SALES ORDER</h3>
                        </div>
                        <div class="text-center" style="background-color: #17a2b8; color: white; padding: 5px;">
                            <h4 style="margin: 0;">INTER OFFICE MEMO</h4>
                        </div>

                        <!-- To Section -->
                        <div style="margin-top: 10px;">
                            <span>
                                <strong>To:</strong>
                            </span>
                        </div>

                        <!-- Department Table (4 columns) -->
                        <table class="table table-borderless o_main_table small mb-1">
                            <tr>
                                <th>
                                    <strong>Engineering</strong>
                                </th>
                                <th>
                                    <strong>Planning &amp; Purchase</strong>
                                </th>
                                <th>
                                    <strong>Accounts</strong>
                                </th>
                                <th>
                                    <strong>Operations</strong>
                                </th>
                                <th>
                                    <strong>Testing  &amp; Quality</strong>
                                </th>
                                <th>
                                    <strong>Store</strong>
                                </th>
                            </tr>
                            <tr>
                                <td>
                                    <span t-field="doc.engineering_id"/>
                                </td>
                                <td>
                                    <span t-field="doc.planning_purchase_id"/>
                                </td>
                                <td>
                                    <span t-field="doc.accounts_id"/>
                                </td>
                                <td>
                                    <span t-field="doc.operations_id"/>
                                </td>
                                <td>
                                    <span t-field="doc.testing_id"/>
                                </td>
                                <td>
                                    <span t-field="doc.store_id"/>
                                </td>
                            </tr>

                        </table>


                        <!-- Customer Details Section -->
                        <div style="margin-top: 15px;">
                            <strong>Customer Details:</strong>
                        </div>
                        <div style="margin-left: 10px;">
                            <span t-field="doc.partner_id"
                                  t-options='{"widget": "contact", "fields": ["name", "address"], "no_marker": True}'/>
                        </div>

                        <!-- Sales Order Info Table -->
                        <table class="table table-bordered" style="line-height: 1;">
                            <tr>
                                <td style="width: 25%;">
                                    <strong>Sales Order No.</strong>
                                </td>
                                <td style="width: 25%;">
                                    <span t-field="doc.name"/>
                                </td>
                                <td style="width: 25%;">
                                    <strong>Revision No.</strong>
                                </td>
                                <td style="width: 25%;">
                                    <span t-field="doc.revision"/>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <strong>Project Reference</strong>
                                </td>
                                <td>
                                    <span t-field="doc.project_reference_id.name"/>
                                </td>
                                <td>
                                    <strong>Date</strong>
                                </td>
                                <td>
                                    <span t-field="doc.date_order" t-options='{"widget": "date"}'/>
                                </td>
                            </tr>
                        </table>

                        <!-- Order Lines Table -->
                        <table class="table table-bordered" style="margin-top: 15px;">
                            <thead style="background-color: #f0f0f0;">
                                <tr>
                                    <th style="width: 5%;">No.</th>
                                    <th style="width: 55%;">Description</th>
                                    <th style="width: 15%;" class="text-center">Quantity (Nos)</th>
                                    <th style="width: 25%;">Special Notes (if any)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="line_index" t-value="0"/>
                                <t t-foreach="doc.order_line" t-as="line">
                                    <t t-set="line_index" t-value="line_index + 1"/>
                                    <tr>
                                        <td class="text-center">
                                            <span t-esc="line_index"/>
                                        </td>
                                        <td>
                                            <span t-field="line.name"/>
                                        </td>
                                        <td class="text-center">
                                            <span t-field="line.product_uom_qty"/>
                                        </td>
                                        <td>
                                            <span t-field="line.note"/>
                                        </td>
                                    </tr>
                                </t>
                                <!-- Total Row -->
                                <tr style="background-color: #f0f0f0;">
                                    <td colspan="2" class="text-center">
                                        <strong>Total Quantity (Nos)</strong>
                                    </td>
                                    <td class="text-center">
                                        <strong>
                                            <t t-set="total_qty" t-value="0"/>
                                            <t t-foreach="doc.order_line" t-as="line">
                                                <t t-set="total_qty" t-value="total_qty + line.product_uom_qty"/>
                                            </t>
                                            <span t-esc="total_qty"/>
                                        </strong>
                                    </td>
                                    <td></td>
                                </tr>
                            </tbody>
                        </table>
                        <br/>
                        <div class="row">
                             <strong>NOTES:</strong>
                            <br/>
                             <div t-field="doc.delivery_order_note"/>
                        </div>

                        <!-- Delivery Schedule Table -->
                        <table class="table table-bordered" style="margin-top: 15px;">
                            <thead>
                                <tr style="background-color: #f0f0f0;">
                                    <th>Lot Number</th>
                                    <th>Transformer Details</th>
                                    <th>Quantity (Nos)</th>
                                    <th>Delivery Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.new_term_ids" t-as="term">
                                    <tr>
                                        <td>
                                            <span t-field="term.name"/>
                                        </td>
                                        <td>
                                            <span t-field="term.term_description"/>
                                        </td>
                                        <td>
                                            <span t-field="term.qty_in_nos"/>
                                        </td>
                                        <td>
                                            <span t-field="term.delivery_date"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                    </div>
                      <div class="footer">
                        <div class="row">
                            <div class="col-4 text-center">
                                <span>Prepared by:</span>
                                <br/>
                                <span t-field="doc.user_id.name"/>
                            </div>
                            <div class="col-4 text-center">
                                <span>Page
                                    <span class="page"/>
                                    /
                                    <span class="topage"/>
                                </span>
                            </div>
                            <div class="col-4 text-center">
                                <span>Approved by:</span>
                                <br/>
                                <span t-field="doc.manager_id.name"/>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
