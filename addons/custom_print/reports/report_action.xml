    <!-- Custom Sale Order Report Action -->
    <record id="action_report_sale_order_custom" model="ir.actions.report">
        <field name="name">Custom Sale Order</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_print.report_sale_order_document_custom</field>
        <field name="report_file">custom_print.report_sale_order_document_custom</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
