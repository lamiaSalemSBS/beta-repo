<odoo>
    <template id="report_packing_list_custom">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <t t-foreach="docs" t-as="doc">
                    <div class="page">
                        <div class="header">
                            <table style="width: 100%; border-collapse: collapse;">
                                <tr>

                                    <td style="width: 65%; vertical-align: top;">
                                        <img t-if="doc.company_id.logo" t-att-src="image_data_uri(doc.company_id.logo)"
                                             style="max-height: 80px; max-width: 200px;" alt="Company Logo"/>
                                    </td>

                                    <td style="width: 35%; text-align: left; vertical-align: top; font-size: 12px; padding-left:70px;">
                                        <strong>
                                            <span t-field="doc.company_id.name"/>
                                        </strong>
                                        <br/>
                                        <span t-field="doc.company_id.street"/>
                                        <t t-if="doc.company_id.street2">,
                                            <span t-field="doc.company_id.street2"/>
                                        </t>
                                        <br/>
                                        <span t-field="doc.company_id.city"/>,
                                        <span t-field="doc.company_id.state_id.name"/>
                                        <br/>
                                        <t t-if="doc.company_id.phone">Tel:
                                            <span t-field="doc.company_id.phone"/>
                                            <br/>
                                        </t>
                                        <t t-if="doc.company_id.email">Email:
                                            <span t-field="doc.company_id.email"/>
                                            <br/>
                                        </t>
                                        <t t-if="doc.company_id.website">Website:
                                            <span t-field="doc.company_id.website"/>
                                            <br/>
                                        </t>
                                    </td>
                                </tr>
                            </table>
                            <div class="text-center"
                                 style="background-color: #008b8a; color: white; padding: 10px; margin-bottom: 20px;">
                                <h2 style="margin: 0;">Packing List</h2>

                            </div>
                        </div>
                        <table style="width: 100%; border-collapse: collapse; border: 1px solid black; margin-bottom: 0px;">

                            <tr>

                                <td style="border: 1px solid black; padding: 5px; font-weight: bold;  font-size: 11px; width:30%;">
                                    Manufacturer / Producer / Beneficiary
                                    <br></br>
                                    (Invoicing Party)
                                </td>

                                <td style="border: 1px solid black; padding: 5px; font-weight: bold; width:30%;">
                                    Consignee
                                </td>

                                <td style="border: 1px solid black; padding: 5px; font-weight: bold; width:20%;">
                                    Packing List No.

                                </td>
                                <td style="border: 1px solid black; padding: 5px; width:20%;">
                                    <span t-field="doc.name"/>
                                </td>
                            </tr>

                            <tr>
                                <td rowspan="6"
                                    style="border: 1px solid black; padding: 5px; font-size: 12px; vertical-align: top;">
                                    <span t-field="doc.company_id.name"/>
                                    <br/>
                                    <span t-field="doc.company_id.street"/>
                                    <t t-if="doc.company_id.street2">,
                                        <span t-field="doc.company_id.street2"/>
                                    </t>
                                    <br/>
                                    <span t-field="doc.company_id.city"/>,
                                    <span t-field="doc.company_id.state_id.name"/>
                                    <br/>
                                    <t t-if="doc.company_id.phone">Tel:
                                        <span t-field="doc.company_id.phone"/>
                                        <br/>
                                    </t>
                                    <t t-if="doc.company_id.email">Email:
                                        <span t-field="doc.company_id.email"/>
                                        <br/>
                                    </t>
                                </td>
                                <td rowspan="6"
                                    style="border: 1px solid black; padding: 5px; font-size: 12px; vertical-align: top;">
                                    <span t-field="doc.partner_id.name"/>
                                    <br/>
                                    <span t-field="doc.partner_id.street"/>
                                    <t t-if="doc.partner_id.street2">,
                                        <span t-field="doc.partner_id.street2"/>
                                    </t>
                                    <br/>
                                    <span t-field="doc.partner_id.city"/>,
                                    <span t-field="doc.partner_id.state_id.name"/>
                                    <br/>
                                    <t t-if="doc.partner_id.phone">Tel:
                                        <span t-field="doc.partner_id.phone"/>
                                        <br/>
                                    </t>
                                    <t t-if="doc.partner_id.email">Email:
                                        <span t-field="doc.partner_id.email"/>
                                        <br/>
                                    </t>
                                </td>
                                <td style="border: 1px solid black; padding: 5px; font-weight: bold;">Packing List Date
                                </td>
                                <td style="border: 1px solid black; padding: 5px;">
                                    <span t-field="doc.invoice_date"/>
                                </td>


                            </tr>

                            <tr>
                                <td style="border: 1px solid black; padding: 5px; font-weight: bold;">Buyer's Order
                                    No.
                                </td>
                                <td style="border: 1px solid black; padding: 5px;">
                                    <span t-field="doc.name"/>
                                </td>
                            </tr>
                            <tr>

                                <td style="border: 1px solid black; padding: 5px; font-weight: bold;">Buyer's Order
                                    Date
                                </td>
                                <td style="border: 1px solid black; padding: 5px;">
                                    <span t-field="doc.invoice_date"/>
                                </td>
                            </tr>
                            <tr>

                                <td colspan="2"
                                    style="   text-align: center; border: 1px solid black; padding: 5px; font-weight: bold;">
                                    Terms
                                    of Payment:
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2" style="   text-align: center; border: 1px solid black; padding: 5px;">
                                    <span t-field="doc.invoice_date"/>
                                </td>

                            </tr>
                            <tr>
                                <td colspan="2"
                                    style="border: 1px solid black; padding: 5px; font-weight: bold;     text-align: center; ">
                                    Incoterm:

                                </td>

                            </tr>


                            <tr>

                                <td style="border: 1px solid black; padding: 5px; font-weight: bold;  ">
                                    Buyer
                                </td>

                                <td style="border: 1px solid black; padding: 5px; font-weight: bold;  ">
                                    Notify
                                </td>

                                <td colspan="2" style="border: 1px solid black; padding: 5px; ">
                                    <span t-field="doc.incoterm_location"/>
                                </td>
                            </tr>

                            <tr>
                                <td rowspan="6"
                                    style="border: 1px solid black; padding: 5px; font-size: 12px; vertical-align: top;">
                                    <span t-field="doc.company_id.name"/>
                                    <br/>
                                    <span t-field="doc.company_id.street"/>
                                    <t t-if="doc.company_id.street2">,
                                        <span t-field="doc.company_id.street2"/>
                                    </t>
                                    <br/>
                                    <span t-field="doc.company_id.city"/>,
                                    <span t-field="doc.company_id.state_id.name"/>
                                    <br/>
                                    <t t-if="doc.company_id.phone">Tel:
                                        <span t-field="doc.company_id.phone"/>
                                        <br/>
                                    </t>
                                    <t t-if="doc.company_id.email">Email:
                                        <span t-field="doc.company_id.email"/>
                                        <br/>
                                    </t>
                                </td>
                                <td rowspan="6"
                                    style="border: 1px solid black; padding: 5px; font-size: 12px; vertical-align: top;">
                                    <span t-field="doc.partner_id.name"/>
                                    <br/>
                                    <span t-field="doc.partner_id.street"/>
                                    <t t-if="doc.partner_id.street2">,
                                        <span t-field="doc.partner_id.street2"/>
                                    </t>
                                    <br/>
                                    <span t-field="doc.partner_id.city"/>,
                                    <span t-field="doc.partner_id.state_id.name"/>
                                    <br/>
                                    <t t-if="doc.partner_id.phone">Tel:
                                        <span t-field="doc.partner_id.phone"/>
                                        <br/>
                                    </t>
                                    <t t-if="doc.partner_id.email">Email:
                                        <span t-field="doc.partner_id.email"/>
                                        <br/>
                                    </t>
                                </td>
                                <td colspan="2"
                                    style=" text-align: center; font-weight: bold;  border: 1px solid black; padding: 5px;">
                                    Place
                                    of Loading:
                                </td>


                            </tr>

                            <tr>
                                <td colspan="2" style=" text-align: center;  border: 1px solid black; padding: 5px;">
                                    <span t-field="doc.incoterm_location"/>
                                </td>
                            </tr>
                            <tr>

                                <td colspan="2"
                                    style=" font-weight: bold; text-align: center;  border: 1px solid black; padding: 5px;">

                                    Place of Discharge:

                                </td>
                            </tr>
                            <tr>
                                <td colspan="2" style=" text-align: center;  border: 1px solid black; padding: 5px;">
                                    <span t-field="doc.incoterm_location"/>
                                </td>

                            </tr>
                            <tr>

                                <td colspan="2"
                                    style="font-weight: bold;  text-align: center;  border: 1px solid black; padding: 5px;">

                                    Vessel Name:


                                </td>
                            </tr>

                            <tr>
                                <td colspan="2" style=" text-align: center;  border: 1px solid black; padding: 5px;">
                                    <span t-field="doc.incoterm_location"/>
                                </td>

                            </tr>


                            <tr>
                                <td style="border: 1px solid black; padding: 5px;">
                                    <strong>Proforma Invoice No.:</strong>
                                    <span t-field="doc.name"/>
                                </td>


                                <td style="border: 1px solid black; padding: 5px;">
                                    <strong>Sales Order No.:</strong>
                                    <span t-field="doc.name"/>
                                </td>

                                <td colspan="2"
                                    style="border: 1px solid black; padding: 5px; font-weight: bold;  text-align: center;  ">
                                    Mode of Transport:
                                </td>

                            </tr>
                            <tr>

                                <td style="border: 1px solid black; padding: 5px;">
                                    <strong>Proforma Invoice Date:</strong>
                                    <span t-field="doc.date"/>
                                </td>
                                <td style="border: 1px solid black; padding: 5px;">
                                    <strong>No. and Kind of Packing:</strong>
                                    <span t-field="doc.name"/>
                                </td>
                                <td colspan="2"
                                    style="border: 1px solid black; padding: 5px; font-weight: bold;  text-align: center;  ">
                                    <span t-field="doc.name"/>
                                </td>

                            </tr>
                            <tr>
                                <td colspan="4"
                                    style="border: 1px solid black; padding: 5px; vertical-align: top; width:50%;">
                                    <strong>Any Other Details:</strong>
                                    <!--                                    <span t-field="doc.incoterm_location"/>-->
                                </td>
                            </tr>


                        </table>


                        <table style="width: 100%; border-collapse: collapse; border: 1px solid black; margin-top: 1px; margin-bottom: 0px;">

                            <thead>
                                <tr style="background-color: #f2f2f2; text-align: center;">
                                    <th style="border: 1px solid black; padding: 5px;">Sl No.</th>
                                    <th style="border: 1px solid black; padding: 5px;">HS Code</th>
                                    <th style="border: 1px solid black; padding: 5px;">Description of Goods</th>
                                    <th style="border: 1px solid black; padding: 5px;">Quantity (Nos)</th>
                                    <th style="border: 1px solid black; padding: 5px;">"Length
                                        (mm)
                                    </th>
                                    <th style="border: 1px solid black; padding: 5px;">Width
                                        (mm)
                                    </th>
                                    <th style="border: 1px solid black; padding: 5px;">Height

                                        (mm)
                                    </th>
                                    <th style="border: 1px solid black; padding: 5px;">Net Weight

                                        (kg)
                                    </th>
                                    <th style="border: 1px solid black; padding: 5px;">Gross Weight

                                        (kg)
                                    </th>
                                    <th style="border: 1px solid black; padding: 5px;">Total Gross Weight with Packing

                                        (kg)
                                    </th>
                                </tr>
                            </thead>

                            <tbody>
                                <tr t-foreach="enumerate(doc.invoice_line_ids, start=1)" t-as="line_data"
                                    style="text-align: center;">
                                    <t t-set="i" t-value="line_data[0]"/>
                                    <t t-set="line" t-value="line_data[1]"/>


                                    <td style="border: 1px solid black; padding: 5px;" t-esc="i"/>
                                    <td style="border: 1px solid black; padding: 5px;"
                                        t-esc="line.product_id.default_code or ''"/>
                                    <td style="border: 1px solid black; padding: 5px; text-align: left;"
                                        t-esc="line.name"/>


                                    <td style="border: 1px solid black; padding: 5px;" t-esc="line.quantity"/>
                                    <td style="border: 1px solid black; padding: 5px;" t-esc="line.price_unit"/>
                                    <td style="border: 1px solid black; padding: 5px;" t-esc="line.price_subtotal"/>
                                    <td style="border: 1px solid black; padding: 5px;" t-esc="line.price_subtotal"/>
                                    <td style="border: 1px solid black; padding: 5px;" t-esc="line.price_subtotal"/>
                                    <td style="border: 1px solid black; padding: 5px;" t-esc="line.price_subtotal"/>
                                    <td style="border: 1px solid black; padding: 5px;" t-esc="line.price_subtotal"/>
                                </tr>
                            </tbody>


                            <tfoot>
                                <tr>
                                    <td colspan="3"
                                        style="border: 1px solid black; padding: 5px; text-align: right; font-weight: bold;">
                                        Total
                                    </td>
                                    <td style="border: 1px solid black; padding: 5px; text-align: left;">
                                        <span t-esc="sum(line.quantity for line in doc.invoice_line_ids)"/>
                                    </td>
                                    <td style="border: 1px solid black; padding: 5px; text-align: left;">
                                    </td>
                                    <td style="border: 1px solid black; padding: 5px; text-align: left;">
                                    </td>
                                    <td style="border: 1px solid black; padding: 5px; text-align: left;">
                                    </td>
                                    <td style="border: 1px solid black; padding: 5px; text-align: left;">
                                    </td>
                                    <td style="border: 1px solid black; padding: 5px; text-align: left;">
                                    </td>
                                    <td style="border: 1px solid black; padding: 5px; text-align: left;">
                                        <span t-esc="sum(line.quantity for line in doc.invoice_line_ids)"/>

                                    </td>
                                </tr>



                                <tr>
                                    <td colspan="3"
                                        style="border: 1px solid black; padding: 5px; text-align: right; font-weight: bold;">
                                        Country of Origin
                                    </td>
                                    <td colspan="7" style="border: 1px solid black; padding: 5px; text-align: left;"
                                        t-esc="doc.company_id.country_id.name"/>
                                </tr>
                            </tfoot>
                        </table>

                        <table style="width: 100%; border-collapse: collapse; border: 1px solid black; margin-top: 0px;">

                            <tr>
                                <td style="border: 1px solid black; padding: 5px; font-weight: bold;">
                                    Declaration:
                                </td>
                            </tr>

                        </table>

                        <div class="footer" style="width: 100%; margin-top: 10px;">
                            <table style="width: 100%; border-collapse: collapse;">
                                <tr>
                                    <td style="width: 30%; vertical-align: top; text-align: left; font-size: 12px;">
                                        For Beta Transformers FZCO,
                                        <br/>
                                        <br/>
                                        Authorized Signatory
                                        <br/>
                                        <br/>
                                        ___________________________
                                    </td>
                                </tr>
                            </table>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
